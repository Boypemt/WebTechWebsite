%% UML Sequence Diagram — Login Handshake
%% Session 06: Security & Auth Logic (slides 18–20)
%% Renders on mermaid.live, GitHub, or VS Code Mermaid Preview

sequenceDiagram
    autonumber
    actor User as User
    participant FE as Frontend<br/>(Browser / Client)
    participant GW as API Gateway
    participant BE as Backend<br/>(Express Server)
    participant DB as Database<br/>(auth_user.json)

    User->>FE: Submit login form<br/>(email, password)

    rect rgb(255, 245, 230)
    Note over FE,GW: Encrypted via HTTPS / TLS
    FE->>GW: POST /api/login<br/>{ email, password }
    GW->>BE: forward request
    end

    BE->>DB: findUser(email)
    DB-->>BE: user record<br/>(email, hashedPassword)<br/>OR null

    alt user not found
        BE-->>GW: 401 Unauthorized<br/>"Invalid email or password"
        GW-->>FE: 401 Unauthorized
        FE-->>User: Show error
    else user found
        Note over BE: bcrypt.compare(<br/>inputPassword,<br/>storedHash)
        alt password mismatch
            BE-->>GW: 401 Unauthorized<br/>"Invalid email or password"
            GW-->>FE: 401 Unauthorized
            FE-->>User: Show error
        else password match
            Note over BE: jwt.sign(payload, SECRET_KEY)<br/>payload = { user_id, role }
            BE-->>GW: 200 OK<br/>{ token: "xxxxx.yyyyy.zzzzz" }
            GW-->>FE: 200 OK { token }
            Note over FE: localStorage.setItem('token', token)
            FE-->>User: Redirect to shop<br/>(logged in)
        end
    end

    Note over FE,BE: All future requests carry:<br/>Authorization: Bearer &lt;token&gt;
